generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String?
  email        String   @unique
  password     String?
  agreeToTerms Boolean  @default(false)
  createdAt    DateTime @default(now())

  resetToken       String?
  resetTokenExpiry DateTime?
  refreshToken     String?

  profile UserProfile?

  googleId String?  @unique
  provider String   @default("local")
  resumes  Resume[]
}

model UserProfile {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  phoneNumber String?
  location    String?
  jobTitle    String?
  website     String?
  bio         String?
  avatar      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  file  String
  title String
  name  String
  email String
  phone String

  skills     String[] // PostgreSQL array
  experience String?

  linkedin  String?
  portfolio String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
