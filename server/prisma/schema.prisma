generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String?
  email        String   @unique
  password     String?
  agreeToTerms Boolean  @default(false)
  createdAt    DateTime @default(now())

  resetToken       String?
  resetTokenExpiry DateTime?
  refreshToken     String?

  profile UserProfile?
  jobs    Job[]

  googleId String?  @unique
  provider String   @default("local")
  resumes  Resume[]
}

model UserProfile {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  phoneNumber String?
  location    String?
  jobTitle    String?
  website     String?
  bio         String?
  avatar      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  file  String
  title String
  name  String
  email String
  phone String

  skills     String[] // PostgreSQL array
  experience String?

  linkedin  String?
  portfolio String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model Job {
  id              Int       @id @default(autoincrement())


  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName     String    @db.VarChar(255)
  jobTitle        String    @db.VarChar(255)
  role            String?   @db.VarChar(255)

  location        String    @db.VarChar(255)
  experience      String?   @db.VarChar(100)

  jobType         JobType
  workMode        WorkMode
  platform        String    @db.VarChar(100)
  jobUrl          String?   @db.Text
  companyWebsite  String?   @db.Text

  recruiterName   String?   @db.VarChar(255)
  recruiterEmail  String?   @db.VarChar(255)

  expectedSalary  Decimal?  @db.Decimal(12, 2)
  offeredSalary   Decimal?  @db.Decimal(12, 2)
  currency        String    @default("INR")

  applicationDate String
  interviewDate   String?
  followUpDate    String?

  status          JobStatus @default(saved)
  priority        Priority  @default(MEDIUM)

  jobDescription  String?   @db.Text
  note            String?   @db.Text
  feedback        String?   @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

}

enum JobType {
  FullTime
  PartTime
  Contract
  Freelance
  Internship
}

enum WorkMode {
  Remote
  Hybrid
  Onsite
}

enum JobStatus {
  saved
  applied
  screening
  interview
  offer
  rejected
  withdrawn
  joined
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}